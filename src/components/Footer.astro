---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" style="font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--color-am-white);">
          Auto<span style="color: var(--color-am-blue);">-Mate</span>
        </a>
        <p>Custom AI automation systems for service-based businesses. We eliminate the manual work so you can focus on growth.</p>
      </div>

      <div>
        <p class="footer-heading">Navigate</p>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div>
        <p class="footer-heading">Get Started</p>
        <ul class="footer-links">
          <li><a href="/contact">Free AI Audit</a></li>
          <li><a href="mailto:kaden@auto-mate.business">kaden@auto-mate.business</a></li>
          <li><a href="tel:8014583118">(801) 458-3118</a></li>
          <li style="color: var(--color-am-subtle); font-size: 0.9rem; margin-top: 4px;">Orem, UT</li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} Auto-Mate AI Solutions. All rights reserved.</p>
      <div style="display: flex; gap: 20px;">
        <a href="/privacy" style="font-size: 0.82rem; color: var(--color-am-subtle); transition: color 0.2s;" onmouseover="this.style.color='var(--color-am-muted)'" onmouseout="this.style.color='var(--color-am-subtle)'">Privacy Policy</a>
        <a href="/terms" style="font-size: 0.82rem; color: var(--color-am-subtle); transition: color 0.2s;" onmouseover="this.style.color='var(--color-am-muted)'" onmouseout="this.style.color='var(--color-am-subtle)'">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
